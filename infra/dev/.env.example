# ============================================================
# .env.example — скопіюй в .env і заповни значення.
# .env НЕ комітити в git (є в .gitignore)!
# ============================================================

TZ=Europe/Kiev

# --- PostgreSQL ---
POSTGRES_DB=vdm_shop
POSTGRES_USER=vdm
POSTGRES_PASSWORD=changeme
POSTGRES_LOCAL_PORT=5432

# --- Redis ---
REDIS_LOCAL_PORT=6379

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- RabbitMQ ---
RABBITMQ_USER=vdm
RABBITMQ_PASSWORD=changeme
RABBITMQ_VHOST=/
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- Spring Boot (якщо розкоментовуєш app у compose) ---
SPRING_LOCAL_PORT=8080
